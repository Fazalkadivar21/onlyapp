{
  "name": "mark-1",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @mark-1/db db:generate",
    "db:migrate": "pnpm --filter @mark-1/db db:migrate",
    "db:seed": "pnpm --filter @mark-1/db db:seed",
    "check:secrets": "pnpm --filter @mark-1/integrations check:secrets"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
